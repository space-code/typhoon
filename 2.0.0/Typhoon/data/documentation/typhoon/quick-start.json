{"kind":"article","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/typhoon\/quick-start"]}],"seeAlsoSections":[{"anchor":"Related-Documentation","title":"Related Documentation","identifiers":["doc:\/\/typhoon.Typhoon\/documentation\/Typhoon\/RetryPolicyService","doc:\/\/typhoon.Typhoon\/documentation\/Typhoon\/RetryPolicyStrategy"]},{"anchor":"Articles","title":"Articles","identifiers":["doc:\/\/typhoon.Typhoon\/documentation\/Typhoon\/installation","doc:\/\/typhoon.Typhoon\/documentation\/Typhoon\/advanced-retry-strategies","doc:\/\/typhoon.Typhoon\/documentation\/Typhoon\/best-practices"],"generated":true}],"sections":[],"metadata":{"title":"Quick Start","modules":[{"name":"Typhoon"}],"role":"article","roleHeading":"Article"},"abstract":[{"text":"Get up and running with Typhoon in minutes.","type":"text"}],"primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"text":"Overview","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"text":"Typhoon is a powerful retry policy framework for Swift that helps you handle transient failures gracefully. This guide will help you integrate Typhoon into your project and start using retry policies immediately.","type":"text"}]},{"type":"heading","level":2,"text":"Basic Usage","anchor":"Basic-Usage"},{"type":"heading","level":3,"text":"Your First Retry","anchor":"Your-First-Retry"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Import Typhoon and create a retry service with a simple constant strategy:"}]},{"type":"codeListing","syntax":"swift","code":["import Typhoon","","let retryService = RetryPolicyService(","    strategy: .constant(retry: 3, duration: .seconds(1))",")","","do {","    let result = try await retryService.retry {","        try await fetchDataFromAPI()","    }","    print(\"Success: \\(result)\")","} catch {","    print(\"Failed after 3 retries: \\(error)\")","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This will:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Try your operation immediately"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"If it fails, wait 1 second and retry","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Repeat up to 3 times","type":"text"}],"type":"paragraph"}]}]},{"type":"heading","level":3,"text":"Network Request Example","anchor":"Network-Request-Example"},{"type":"paragraph","inlineContent":[{"text":"Here’s a practical example with URLSession:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["import Foundation","import Typhoon","","func fetchUser(id: String) async throws -> User {","    let retryService = RetryPolicyService(","        strategy: .exponential(retry: 3, duration: .milliseconds(500))","    )","    ","    return try await retryService.retry {","        let url = URL(string: \"https:\/\/api.example.com\/users\/\\(id)\")!","        let (data, response) = try await URLSession.shared.data(from: url)","        ","        guard let httpResponse = response as? HTTPURLResponse,","              httpResponse.statusCode == 200 else {","            throw NetworkError.invalidResponse","        }","        ","        return try JSONDecoder().decode(User.self, from: data)","    }","}"]},{"type":"heading","level":2,"text":"Choosing a Strategy","anchor":"Choosing-a-Strategy"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Typhoon provides three retry strategies:"}]},{"type":"heading","level":3,"text":"Constant Strategy","anchor":"Constant-Strategy"},{"type":"paragraph","inlineContent":[{"text":"Best for predictable, fixed delays:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["\/\/ Retry 5 times with 2 seconds between attempts",".constant(retry: 5, duration: .seconds(2))"]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Timeline:"}],"type":"strong"},{"type":"text","text":" 0s (initial) → 2s → 2s → 2s → 2s → 2s"}]},{"type":"heading","level":3,"text":"Exponential Strategy","anchor":"Exponential-Strategy"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Ideal for backing off from failing services:"}]},{"type":"codeListing","syntax":"swift","code":["\/\/ Retry 4 times with exponentially increasing delays",".exponential(retry: 4, multiplier: 2.0, duration: .seconds(1))"]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Timeline:","type":"text"}]},{"type":"text","text":" 0s (initial) → 1s → 2s → 4s → 8s"}]},{"type":"heading","level":3,"text":"Exponential with Jitter","anchor":"Exponential-with-Jitter"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Best for preventing thundering herd problems:"}]},{"type":"codeListing","syntax":"swift","code":["\/\/ Retry with exponential backoff, jitter, and cap",".exponential(","    retry: 5,","    jitterFactor: 0.2,","    maxInterval: .seconds(30),","    multiplier: 2.0,","    duration: .seconds(1)",")"]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Timeline:","type":"text"}]},{"text":" 0s (initial) → ~1s → ~2s → ~4s → ~8s → ~16s (with randomization)","type":"text"}]},{"type":"heading","level":2,"text":"Common Patterns","anchor":"Common-Patterns"},{"type":"heading","level":3,"text":"Wrapping in a Service Class","anchor":"Wrapping-in-a-Service-Class"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Create a reusable service with built-in retry logic:"}]},{"type":"codeListing","syntax":"swift","code":["import Typhoon","","class APIClient {","    private let retryService = RetryPolicyService(","        strategy: .exponential(retry: 3, duration: .milliseconds(500))","    )","    ","    func get<T: Decodable>(endpoint: String) async throws -> T {","        try await retryService.retry {","            let url = URL(string: \"https:\/\/api.example.com\/\\(endpoint)\")!","            let (data, _) = try await URLSession.shared.data(from: url)","            return try JSONDecoder().decode(T.self, from: data)","        }","    }","}","","\/\/ Usage","let client = APIClient()","let user: User = try await client.get(endpoint: \"users\/123\")"]},{"type":"heading","level":3,"text":"Error Handling","anchor":"Error-Handling"},{"type":"paragraph","inlineContent":[{"text":"Handle specific errors after all retries are exhausted:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["do {","    let data = try await retryService.retry {","        try await performOperation()","    }","    \/\/ Handle success","} catch NetworkError.serverUnavailable {","    print(\"Server is down\")","} catch NetworkError.timeout {","    print(\"Request timed out\")","} catch {","    print(\"Unexpected error: \\(error)\")","}"]},{"type":"heading","level":3,"text":"Configuration for Different Scenarios","anchor":"Configuration-for-Different-Scenarios"},{"type":"codeListing","syntax":"swift","code":["\/\/ Quick operations (file I\/O, cache access)","let quickRetry = RetryPolicyService(","    strategy: .constant(retry: 3, duration: .milliseconds(100))",")","","\/\/ Network requests","let networkRetry = RetryPolicyService(","    strategy: .exponential(retry: 4, multiplier: 1.5, duration: .seconds(1))",")","","\/\/ Critical operations (payments, data persistence)","let criticalRetry = RetryPolicyService(","    strategy: .exponential(","        retry: 5,","        jitterFactor: 0.15,","        maxInterval: .seconds(60),","        multiplier: 2.0,","        duration: .seconds(2)","    )",")"]},{"type":"heading","level":2,"text":"Next Steps","anchor":"Next-Steps"},{"type":"paragraph","inlineContent":[{"text":"Now that you have the basics, explore:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/typhoon.Typhoon\/documentation\/Typhoon\/advanced-retry-strategies"},{"text":" - Deep dive into retry strategies","type":"text"}],"type":