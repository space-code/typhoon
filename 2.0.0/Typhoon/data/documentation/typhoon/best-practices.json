{"abstract":[{"type":"text","text":"Learn the recommended patterns and practices for using Typhoon effectively."}],"hierarchy":{"paths":[["doc:\/\/typhoon.Typhoon\/documentation\/Typhoon"]]},"identifier":{"url":"doc:\/\/typhoon.Typhoon\/documentation\/Typhoon\/best-practices","interfaceLanguage":"swift"},"sections":[],"kind":"article","schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"modules":[{"name":"Typhoon"}],"roleHeading":"Article","title":"Best Practices","role":"article"},"primaryContentSections":[{"content":[{"type":"heading","text":"Overview","anchor":"Overview","level":2},{"type":"paragraph","inlineContent":[{"text":"This guide covers best practices, common pitfalls, and recommended patterns for implementing retry logic in production applications.","type":"text"}]},{"type":"heading","text":"Strategy Selection","anchor":"Strategy-Selection","level":2},{"type":"heading","text":"Choose Based on Use Case","anchor":"Choose-Based-on-Use-Case","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Different scenarios require different retry strategies:"}]},{"code":["\/\/ ✅ Fast local operations (file I\/O, cache)","let localRetry = RetryPolicyService(","    strategy: .constant(retry: 3, duration: .milliseconds(100))",")","","\/\/ ✅ Standard API calls","let apiRetry = RetryPolicyService(","    strategy: .exponential(retry: 4, multiplier: 2.0, duration: .seconds(1))",")","","\/\/ ✅ High-traffic services","let highTrafficRetry = RetryPolicyService(","    strategy: .exponential(","        retry: 5,","        jitterFactor: 0.2,","        maxInterval: 60,","        multiplier: 2.0,","        duration: .seconds(1)","    )",")","","\/\/ ❌ Wrong - Too many retries for quick operation","let badRetry = RetryPolicyService(","    strategy: .exponential(retry: 20, duration: .seconds(10))",")"],"type":"codeListing","syntax":"swift"},{"type":"heading","text":"Recommended Configurations","anchor":"Recommended-Configurations","level":3},{"rows":[[[{"type":"paragraph","inlineContent":[{"text":"Operation Type","type":"text"}]}],[{"inlineContent":[{"text":"Strategy","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Retry Count"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Base Duration"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Notes"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Cache access","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Constant","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"2-3"}],"type":"paragraph"}],[{"inlineContent":[{"text":"50-100ms","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Fast recovery","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Database query","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Constant","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"3-5"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"100-500ms"}]}],[{"type":"paragraph","inlineContent":[{"text":"Predictable delays","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"REST API","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Exponential"}]}],[{"type":"paragraph","inlineContent":[{"text":"3-4","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"500ms-1s","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Standard backoff","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"GraphQL API"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Exponential"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"3-5"}]}],[{"type":"paragraph","inlineContent":[{"text":"1-2s","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Handle complex queries"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"File upload","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Exponential + Jitter"}]}],[{"type":"paragraph","inlineContent":[{"text":"5-7","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"2-5s"}]}],[{"type":"paragraph","inlineContent":[{"text":"Large operations","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Critical payment"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Exponential + Jitter"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"5-10"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"1-2s"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Maximum reliability"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Rate-limited API"}]}],[{"type":"paragraph","inlineContent":[{"text":"Constant","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"3-5","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Based on rate limit"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Respect limits"}]}]]],"type":"table","header":"row"},{"text":"Service Architecture","level":2,"type":"heading","anchor":"Service-Architecture"},{"text":"Reuse Service Instances","level":3,"type":"heading","anchor":"Reuse-Service-Instances"},{"type":"paragraph","inlineContent":[{"text":"Create retry services at the appropriate scope:","type":"text"}]},{"type":"codeListing","code":["\/\/ ✅ Good - Singleton or service property","class APIClient {","    static let shared = APIClient()","    ","    private let retryService = RetryPolicyService(","        strategy: .exponential(retry: 3, duration: .seconds(1))","    )","    ","    func fetchUser(id: String) async throws -> User {","        try await retryService.retry {","            try await performFetch(id: id)","        }","    }","}","","\/\/ ✅ Good - Dependency injection","class DataRepository {","    private let retryService: RetryPolicyService","    ","    init(retryService: RetryPolicyService = .default) {","        self.retryService = retryService","    }","}","","\/\/ ❌ Bad - Creating new instances repeatedly","func fetchData() async throws -> Data {","    let service = RetryPolicyService(...)  \/\/ Don't do this!","    return try await service.retry { ... }","}"],"syntax":"swift"},{"text":"Organize by Layer","level":3,"type":"heading","anchor":"Organize-by-Layer"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Structure retry services by architectural layer:"}]},{"type":"codeListing","code":["\/\/ Network Layer","class NetworkRetryService {","    static let standard = RetryPolicyService(","        strategy: .exponential(retry: 3, duration: .milliseconds(500))","    )","    ","    static let critical = RetryPolicyService(","        strategy: .exponential(","            retry: 5,","            jitterFactor: 0.2,","            maxInterval: 60,","            multiplier: 2.0,","            duration: .seconds(1)","        )","    )","}","","\/\/ Data Layer","class DataRetryService {","    static let cache = RetryPolicyService(","        strategy: .constant(retry: 2, duration: .milliseconds(50))","    )","    ","    static let database = RetryPolicyService(","        strategy: .constant(retry: 3, duration: .milliseconds(200))","    )","}","","\/\/ Usage","class UserRepository {","    func fetchUser(id: String) async throws -> User {","        try await NetworkRetryService.standard.retry {","            try await api.getUser(id: id)","        }","    }","    ","    func cacheUser(_ user: User) async throws {","        try await DataRetryService.cache.retry {","            try cache.save(user)","        }","    }","}"],"syntax":"swift"},{"text":"Error Handling","level":2,"type":"heading","anchor":"Error-Handling"},{"text":"Selective Retry","level":3,"type":"heading","anchor":"Selective-Retry"},{"type":"paragraph","inlineContent":[{"text":"Don’t retry errors that won’t benefit from retrying:","type":"text"}]},{"type":"codeListing","code":["enum APIError: Error {","    case networkFailure       \/\/ ✅ Retry","    case serverError         \/\/ ✅ Retry (5xx)","    case timeout             \/\/ ✅ Retry","    case rateLimited         \/\/ ✅ Retry with delay","    case unauthorized        \/\/ ❌ Don't retry (401)","    case forbidden           \/\/ ❌ Don't retry (403)","    case notFound            \/\/ ❌ Don't retry (404)","    case badRequest          \/\/ ❌ Don't retry (400)","    case invalidData         \/\/ ❌ Don't retry","}","","func fetchWithSelectiveRetry() async throws -> Data {","    do {","        return try await retryService.retry({","            try await performRequest()","        }, onFailure: { error in ","            if let error = error as? APIError {","                switch error {","                case .unauthorized, .forbidden, .notFound, .badRequest, .invalidData:","                    \/\/ Don't retry client errors","                    throw error","                case .networkFailure, .serverError, .timeout, .rateLimited:","                    \/\/ These were already retried","                    throw error","            }","        })","    } catch let error {","        throw error","    }","}"],"syntax":"swift"},{"text":"Performance Optimization","level":2,"type":"heading","anchor":"Performance-Optimization"},{"text":"Avoid Over-Retrying","level":3,"type":"heading","anchor":"Avoid-Over-Retrying"},{"type":"paragraph","inlineContent":[{"text":"Balance persistence with resource usage:","type":"text"}]},{"type":"codeListing","code":["\/\/ ❌ Bad - Too aggressive","let badService = RetryPolicyService(","    strategy: .constant(retry: 100, duration: .milliseconds(10))",")","","\/\/ ✅ Good - Reasonable limits","let goodService = RetryPolicyService(","    strategy: .exponential(","        retry: 5,","        maxInterval: 60,","        duration: .seconds(1)","    )",")"],"syntax":"swift"},{"text":"Set Appropriate Timeouts","level":3,"type":"heading","anchor":"Set-Appropriate-Timeouts"},{"type":"paragraph","inlineContent":[{"text":"Combine retries with timeouts to prevent indefinite waiting:","type":"text"}]},{"type":"codeListing","code":["func fetchWithTimeout<T: Sendable>(","    timeout: TimeInterval,","    operation: @Sendable @escaping () async throws -> T",") async throws -> T {","    try await withThrowingTaskGroup(of: T.self) { group in","        group.addTask {","            try await retryService.retry(operation)","        }","        ","        group.addTask {","            try await Task.sleep(nanoseconds: UInt64(timeout * 1_000_000_000))","            throw TimeoutError.exceeded","        }","        ","        let result = try await group.next()!","        group.cancelAll()","        return result","    }","}"],"syntax":"swift"},{"text":"Testing","level":2,"type":"heading","anchor":"Testing"},{"text":"Mock Retry Behavior","level":3,"type":"heading","anchor":"Mock-Retry-Behavior"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Create testable retry scenarios:"}]},{"type":"codeListing","code":["actor MockService {","    var failureCount: Int","    private var currentAttempt = 0","    ","    init(failureCount: Int) {","        self.failureCount = failureCount","    }","    ","    func operation() throws -> String {","        currentAttempt += 1","        if currentAttempt <= failureCount {","            throw MockError.transient","        }","        return \"Success\"","    }","}","","\/\/ Test","func testRetrySucceedsAfterFailures() async throws {","    let mock = MockService(failureCount: 2)","    let service = RetryPolicyService(","        strategy: .constant(retry: 3, duration: .milliseconds(10))","    )","    ","    let result = try await service.retry {","        try await mock.operation()","    }","    ","    XCTAssertEqual(result, \"Success\")","}"],"syntax":"swift"},{"text":"Test Strategy Behavior","level":3,"type":"heading","anchor":"Test-Strategy-Behavior"},{"type":"paragraph","inlineContent":[{"text":"Verify retry timing and attempts:","type":"text"}]},{"type":"codeListing","code":["func testExponentialBackoff() async throws {","    let startTime = Date()","    var attempts = 0","    ","    do {","        try await retryService.retry {","            attempts += 1","            throw TestError.failed","        }","    } catch {","        \/\/ Expected to fail","    }","    ","    let duration = Date().timeIntervalSince(startTime)","    ","    XCTAssertEqual(attempts, 4)  \/\/ Initial + 3 retries","    XCTAssertGreaterThan(duration, 7.0)  \/\/ 1 + 2 + 4 seconds","}"],"syntax":"swift"},{"text":"Common Pitfalls","level":2,"type":"heading","anchor":"Common-Pitfalls"},{"text":"Don’t Retry Non-Idempotent Operations","level":3,"type":"heading","anchor":"Dont-Retry-Non-Idempotent-Operations"},{"type":"paragraph","inlineContent":[{"text":"Be careful with operations that shouldn’t be repeated:","type":"text"}]},{"type":"codeListing","code":["\/\/ ❌ Dangerous - May create duplicate payments","func processPayment(amount: Decimal) async throws {","    try await retryService.retry {","        try await paymentGateway.charge(amount)","    }","}","","\/\/ ✅ Safe - Use idempotency key","func processPayment(amount: Decimal, idempotencyKey: String) async throws {","    try await retryService.retry {","        try await paymentGateway.charge(","            amount: amount,","            idempotencyKey: idempotencyKey","        )","    }","}"],"syntax":"swift"},{"text":"Don’t Ignore Cancellation","level":3,"type":"heading","anchor":"Dont-Ignore-Cancellation"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Respect task cancellation:"}]},{"type":"codeListing","code":["\/\/ ✅ Good - Check cancellation","try await retryService.retry {","    try Task.checkCancellation()","    return try await operation()","}","","\/\/ ❌ Bad - Ignores cancellation","try await retryService.retry {","    return try await operation()  \/\/ May continue after cancel","}"],"syntax":"swift"},{"text":"Don’t Nest Retries","level":3,"type":"heading","anchor":"Dont-Nest-Retries"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Avoid multiple retry layers:"}]},{"type":"codeListing","code":["\/\/ ❌ Bad - Nested retries multiply attempts","func fetch() async throws -> Data {","    try await outerRetry.retry {","        try await innerRetry.retry {  \/\/ Don't do this!","            try await actualFetch()","        }","    }","}","","\/\/ ✅ Good - Single retry layer","func fetch() async throws -> Data {","    try await retryService.retry {","        try await actualFetch()","    }","}"],"syntax":"swift"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/typhoon\/best-practices"]}],"seeAlsoSections":[{"identifiers":["doc:\/\/typhoon.Typhoon\/documentation\/Typhoon\/quick-start","doc:\/\/typhoon.Typhoon\/documentation\/Typhoon\/advanced-retry-strategies","doc:\/\/typhoon.Typhoon\/documentation\/Typhoon\/RetryPolicyService"],"title":"Related Documentation","anchor":"Related-Documentation"},{"identifiers":["doc:\/\/typhoon.Typhoon\/documentation\/Typhoon\/installation","doc:\/\/typhoon.Typhoon\/documentation\/Typhoon\/quick-start","doc:\/\/typhoon.Typhoon\/documentation\/Typhoon\/advanced-retry-strategies"],"title":"Articles","generated":true,"anchor":"Articles"}],"references":{"doc://typhoon.Typhoon/documentation/Typhoon/advanced-retry-strategies":{"url":"\/documentation\/typhoon\/advanced-retry-strategies","abstract":[{"type":"text","text":"Master advanced retry patterns and optimization techniques."}],"type":"topic","role":"article","title":"Advanced Retry Strategies","identifier":"doc:\/\/typhoon.Typhoon\/documentation\/Typhoon\/advanced-retry-strategies","kind":"article"},"doc://typhoon.Typhoon/documentation/Typhoon/installation":{"url":"\/documentation\/typhoon\/installation","identifier":"doc:\/\/typhoon.Typhoon\/documentation\/Typhoon\/installation","role":"article","abstract":[{"text":"A guide to installing the Typhoon package into your Swift project using Swift Package Manager.","type":"text"}],"title":"Installation","type":"topic","kind":"article"},"doc://typhoon.Typhoon/documentation/Typhoon":{"type":"topic","kind":"symbol","title":"Typhoon","abstract":[],"identifier":"doc:\/\/typhoon.Typhoon\/documentation\/Typhoon","url":"\/documentation\/typhoon","role":"collection"},"doc://typhoon.Typhoon/documentation/Typhoon/quick-start":{"kind":"article","title":"Quick Start","identifier":"doc:\/\/typhoon.Typhoon\/documentation\/Typhoon\/quick-start","role":"article","abstract":[{"type":"text","text":"Get up and running with Typhoon in minutes."}],"url":"\/documentation\/typhoon\/quick-start","type":"topic"},"doc://typhoon.Typhoon/documentation/Typhoon/RetryPolicyService":{"type":"topic","title":"RetryPolicyService","role":"symbol","kind":"symbol","navigatorTitle":[{"text":"RetryPolicyService","kind":"identifier"}],"abstract":[{"code":"RetryPolicyService","type":"codeVoice"},{"text":" provides a high-level API for retrying asynchronous","type":"text"},{"text":" ","type":"text"},{"text":"operations using configurable retry strategies.","type":"text"}],"fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"RetryPolicyService"}],"url":"\/documentation\/typhoon\/retrypolicyservice","identifier":"doc:\/\/typhoon.Typhoon\/documentation\/Typhoon\/RetryPolicyService"}}}