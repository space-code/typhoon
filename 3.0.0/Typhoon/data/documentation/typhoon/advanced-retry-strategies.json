{"kind":"article","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/typhoon.Typhoon\/documentation\/Typhoon\/advanced-retry-strategies"},"schemaVersion":{"patch":0,"minor":3,"major":0},"abstract":[{"text":"Master advanced retry patterns and optimization techniques.","type":"text"}],"primaryContentSections":[{"content":[{"anchor":"Overview","type":"heading","level":2,"text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This guide covers advanced usage patterns, performance optimization, and sophisticated retry strategies for complex scenarios."}]},{"anchor":"How-Retry-Mechanism-Works","type":"heading","level":2,"text":"How Retry Mechanism Works"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Understanding the retry flow is crucial for effective error handling:"}]},{"syntax":"swift","type":"codeListing","code":["\/\/ Configuration: retry: 3 means 3 RETRY attempts","let strategy = RetryStrategy.exponential(","    retry: 3,","    multiplier: 2.0,","    duration: .seconds(1)",")"]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Total Execution Flow:"}]}]},{"header":"row","type":"table","rows":[[[{"inlineContent":[{"type":"text","text":"Attempt Type"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Attempt #"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Delay Before"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Description"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Initial","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"1","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"0s","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"First execution (not a retry)","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Retry","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"2"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"1s"}],"type":"paragraph"}],[{"inlineContent":[{"text":"First retry after failure","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Retry","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"3"}],"type":"paragraph"}],[{"inlineContent":[{"text":"2s","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Second retry after failure","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Retry"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"4"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"4s"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Third retry after failure","type":"text"}],"type":"paragraph"}]]]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Key Points:"}]}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"retry"},{"type":"text","text":" parameter specifies the number of "},{"type":"strong","inlineContent":[{"type":"text","text":"retry attempts"}]},{"type":"text","text":", not total attempts"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Total attempts = 1 (initial) + N (retries)"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"retry: 3"},{"text":" means ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"4 total attempts"}]},{"text":" (1 initial + 3 retries)","type":"text"}]}]},{"content":[{"inlineContent":[{"code":"onFailure","type":"codeVoice"},{"text":" callback is invoked after ","type":"text"},{"inlineContent":[{"text":"every","type":"text"}],"type":"strong"},{"text":" failed attempt, including the initial one","type":"text"}],"type":"paragraph"}]}]},{"anchor":"Strategy-Deep-Dive","type":"heading","level":2,"text":"Strategy Deep Dive"},{"anchor":"Understanding-Exponential-Backoff","type":"heading","level":3,"text":"Understanding Exponential Backoff"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Exponential backoff progressively increases wait times to avoid overwhelming recovering services:"}]},{"syntax":"swift","type":"codeListing","code":["let strategy = RetryStrategy.exponential(","    retry: 5,                    \/\/ 5 retry attempts","    multiplier: 2.0,","    duration: .seconds(1)",")"]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Calculation:","type":"text"}],"type":"strong"},{"type":"text","text":" "},{"type":"codeVoice","code":"delay = baseDuration × multiplier^(attemptNumber - 1)"}]},{"rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Attempt Type"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Total Attempt"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Calculation"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Delay Before"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Initial"}]}],[{"type":"paragraph","inlineContent":[{"text":"1","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"-"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"0s (immediate)"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Retry 1","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"2","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"1 × 2⁰"}]}],[{"type":"paragraph","inlineContent":[{"text":"1s","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Retry 2","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"3","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"1 × 2¹","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"2s"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Retry 3","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"4"}]}],[{"type":"paragraph","inlineContent":[{"text":"1 × 2²","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"4s","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Retry 4","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"5"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"1 × 2³"}]}],[{"type":"paragraph","inlineContent":[{"text":"8s","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Retry 5","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"6","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"1 × 2⁴","type":"text"}]}],[{"inlineContent":[{"text":"16s","type":"text"}],"type":"paragraph"}]]],"type":"table","header":"row"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Total: 6 attempts (1 initial + 5 retries)","type":"text"}]}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Multiplier effects:"}],"type":"strong"}]},{"code":["\/\/ Aggressive backoff (multiplier: 3.0)","\/\/ Initial: 0s → Retry: 1s → 3s → 9s → 27s → 81s","","\/\/ Moderate backoff (multiplier: 1.5)","\/\/ Initial: 0s → Retry: 1s → 1.5s → 2.25s → 3.375s → 5.0625s","","\/\/ Slow backoff (multiplier: 1.2)","\/\/ Initial: 0s → Retry: 1s → 1.2s → 1.44s → 1.728s → 2.074s"],"type":"codeListing","syntax":"swift"},{"type":"heading","level":3,"anchor":"Jitter-Preventing-Thundering-Herd","text":"Jitter: Preventing Thundering Herd"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When multiple clients retry simultaneously, they can overwhelm a recovering service. Jitter adds randomization to prevent this:"}]},{"code":["let strategy = RetryStrategy.exponential(","    retry: 5,                          \/\/ 5 retry attempts","    jitterFactor: 0.2,                 \/\/ ±20% randomization","    maxInterval: .seconds(30),         \/\/ Cap at 30 seconds","    multiplier: 2.0,","    duration: .seconds(1)",")"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Without jitter:"}]}]},{"code":["Client 1: 0s(init) → 1s → 2s → 4s → 8s → 16s","Client 2: 0s(init) → 1s → 2s → 4s → 8s → 16s","Client 3: 0s(init) → 1s → 2s → 4s → 8s → 16s","All hit server simultaneously! 💥"],"type":"codeListing","syntax":null},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"With jitter:"}]}]},{"code":["Client 1: 0s(init) → 0.9s → 2.1s → 3.8s → 8.2s → 15.7s","Client 2: 0s(init) → 1.1s → 1.9s → 4.3s → 7.7s → 16.4s","Client 3: 0s(init) → 0.8s → 2.2s → 3.9s → 8.1s → 15.8s","Traffic spread out! ✅"],"type":"codeListing","syntax":null},{"type":"heading","level":3,"anchor":"Maximum-Interval-Capping","text":"Maximum Interval Capping"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Prevent delays from growing unbounded:"}]},{"code":[".exponential(","    retry: 10,                      \/\/ 10 retry attempts = 11 total","    jitterFactor: 0.1,","    maxInterval: .seconds(60),      \/\/ Never wait more than 60 seconds","    multiplier: 2.0,","    duration: .seconds(1)",")"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Without cap:"}],"type":"strong"},{"type":"text","text":""},{"type":"text","text":" "},{"type":"text","text":"Initial → 1s → 2s → 4s → 8s → 16s → 32s → 64s → 128s → 256s → 512s"}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"With 60s cap:"}]},{"type":"text","text":""},{"type":"text","text":" "},{"type":"text","text":"Initial → 1s → 2s → 4s → 8s → 16s → 32s → 60s → 60s → 60s → 60s"}]},{"type":"heading","level":2,"anchor":"Advanced-Patterns","text":"Advanced Patterns"},{"type":"heading","level":3,"anchor":"Conditional-Retry-Logic","text":"Conditional Retry Logic"},{"type":"paragraph","inlineContent":[{"text":"Retry only for specific error types:","type":"text"}]},{"code":["enum NetworkError: Error {","    case serverError","    case clientError","    case timeout","    case connectionLost","}","","func fetchWithConditionalRetry() async throws -> Data {","    let retryService = RetryPolicyService(","        strategy: .exponential(retry: 3, duration: .seconds(1))","    )","    ","    do {","        ","        return try await retryService.retry({","            try await performRequest()","        }, onFailure: { error in","            if let error = error as? NetworkError {","                switch error {","                case .serverError, .timeout, .connectionLost:","                    \/\/ These errors were already retried","                    return .retry","                case .clientError:","                    \/\/ Don't retry client errors (4xx)","                    return .stop","                }","            }","","            return true","        })","    } catch let error as RetryPolicyError {","        switch error {","        case .retryLimitExceeded:","            \/\/ All retry attempts exhausted","            print(\"Retry limit exceeded after multiple attempts\")","            throw error","        }","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"heading","level":3,"anchor":"Retry-with-Timeout","text":"Retry with Timeout"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Combine retry logic with overall timeout:"}]},{"code":["func fetchWithTimeout() async throws -> Data {","    let retryService = RetryPolicyService(","        strategy: .exponential(retry: 5, duration: .seconds(1))","    )","    ","    return try await withThrowingTaskGroup(of: Data.self) { group in","        \/\/ Add retry task","        group.addTask {","            try await retryService.retry {","                try await performRequest()","            }","        }","        ","        \/\/ Add timeout task","        group.addTask {","            try await Task.sleep(nanoseconds: 30_000_000_000) \/\/ 30 seconds","            throw TimeoutError.exceeded","        }","        ","        \/\/ Return first result or throw first error","        guard let result = try await group.next() else {","            throw TimeoutError.unknown","        }","        ","        group.cancelAll()","        return result","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"heading","level":3,"anchor":"Adaptive-Retry-Strategy","text":"Adaptive Retry Strategy"},{"type":"paragraph","inlineContent":[{"text":"Adjust strategy based on error patterns:","type":"text"}]},{"code":["actor AdaptiveRetryService {","    private var consecutiveFailures = 0","    private let maxConsecutiveFailures = 3","    ","    func retry<T: Sendable>(_ operation: @Sendable () async throws -> T) async throws -> T {","        let strategy = selectStrategy()","        let retryService = RetryPolicyService(strategy: strategy)","        ","        do {","            let result = try await retryService.retry(operation)","            consecutiveFailures = 0","            return result","        } catch {","            consecutiveFailures += 1","            throw error","        }","    }","    ","    private func selectStrategy() -> RetryPolicyStrategy {","        if consecutiveFailures >= maxConsecutiveFailures {","            \/\/ System under stress - use conservative strategy","            \/\/ 1 initial + 3 retries with longer delays","            return .exponential(","                retry: 3,","                jitterFactor: 0.3,","                maxInterval: 120,","                multiplier: 3.0,","                duration: .seconds(5)","            )","        } else {","            \/\/ Normal operation - use standard strategy","            \/\/ 1 initial + 4 retries","            return .exponential(","                retry: 4,","                multiplier: 2.0,","                duration: .seconds(1)","            )","        }","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"heading","level":3,"anchor":"Retry-with-Progress-Tracking","text":"Retry with Progress Tracking"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Monitor retry attempts:"}]},{"code":["actor RetryProgressTracker {","    var onRetry: ((Int, Error) async -> Void)?","    ","    private let maxRetries = 5","","    private final class AttemptCounter {","        var count: Int = 0","    }","","    func fetchWithProgress<T>(","        operation: @escaping () async throws -> T","    ) async throws -> T {","        ","        let counter = AttemptCounter()","        ","        let retryService = RetryPolicyService(","            strategy: .exponential(retry: maxRetries, duration: .seconds(1))","        )","        ","        return try await retryService.retry {","            counter.count += 1","            ","            do {","                return try await operation()","            } catch {","                if counter.count < self.maxRetries {","                    await self.notifyOnRetry(attemptCount: counter.count, error: error)","                }","                ","                throw error","            }","        }","    }","","    private func notifyOnRetry(attemptCount: Int, error: Error) async {","        await onRetry?(attemptCount, error)","    }","}","","\/\/ Usage","let tracker = RetryProgressTracker()","tracker.onRetry = { attempt, error in","    print(\"Retry attempt \\(attempt) after error: \\(error)\")","}","","let data = try await tracker.fetchWithProgress {","    try await fetchFromAPI()","}"],"type":"codeListing","syntax":"swift"},{"type":"heading","level":2,"anchor":"Performance-Optimization","text":"Performance Optimization"},{"type":"heading","level":3,"anchor":"Choosing-the-Right-Strategy","text":"Choosing the Right Strategy"},{"type":"table","header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"text":"Scenario","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Strategy","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Rationale","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Fast local operations"}]}],[{"type":"paragraph","inlineContent":[{"text":"Constant (3, 100ms)","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Quick retries for transient issues"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Network requests"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Exponential (4, 500ms-1s)"}]}],[{"type":"paragraph","inlineContent":[{"text":"Give service time to recover","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"High-traffic APIs","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Exponential with jitter"}]}],[{"type":"paragraph","inlineContent":[{"text":"Prevent synchronized retries","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Critical operations"}]}],[{"type":"paragraph","inlineContent":[{"text":"Exponential with jitter + cap","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Balance persistence with resource usage"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Rate-limited APIs"}]}],[{"type":"paragraph","inlineContent":[{"text":"Constant with long delay","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Respect rate limits","type":"text"}]}]]]},{"type":"heading","level":3,"anchor":"Memory-Management","text":"Memory Management"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Typhoon is designed to be memory-efficient:"}]},{"code":["\/\/ ✅ Good - Reuse service instance","class DataRepository {","    private let retryService = RetryPolicyService(","        strategy: .exponential(retry: 3, duration: .seconds(1))","    )","    ","    func fetchData() async throws -> Data {","        try await retryService.retry {","            try await performFetch()","        }","    }","}","","\/\/ ❌ Avoid - Creating new instances repeatedly","func fetchData() async throws -> Data {","    let retryService = RetryPolicyService(  \/\/ Creates new instance each time","        strategy: .exponential(retry: 3, duration: .seconds(1))","    )","    return try await retryService.retry {","        try await performFetch()","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"heading","level":3,"anchor":"Cancellation-Support","text":"Cancellation Support"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Typhoon respects task cancellation:"}]},{"code":["let task = Task {","    let retryService = RetryPolicyService(","        strategy: .exponential(retry: 10, duration: .seconds(5))","    )","    ","    return try await retryService.retry {","        try Task.checkCancellation()  \/\/ Respects cancellation","        return try await longRunningOperation()","    }","}","","\/\/ Cancel after 10 seconds","Task {","    try await Task.sleep(nanoseconds: 10_000_000_000)","    task.cancel()","}"],"type":"codeListing","syntax":"swift"},{"type":"heading","level":2,"anchor":"Testing-Strategies","text":"Testing Strategies"},{"type":"heading","level":3,"anchor":"Mock-Retry-Behavior","text":"Mock Retry Behavior"},{"code":["class MockRetryService {","    var shouldSucceedAfter: Int = 2","    private var attemptCount = 0","    ","    func simulateRetry() async throws -> String {","        attemptCount += 1","        ","        if attemptCount < shouldSucceedAfter {","            throw MockError.transient","        }","        ","        return \"Success\"","    }","}","","\/\/ Test","let mock = MockRetryService()","mock.shouldSucceedAfter = 3","","let retryService = RetryPolicyService(","    strategy: .constant(retry: 5, duration: .milliseconds(10))",")","","let result = try await retryService.retry {","    try await mock.simulateRetry()","}","","XCTAssertEqual(result, \"Success\")"],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"seeAlsoSections":[{"title":"Related Documentation","identifiers":["doc:\/\/typhoon.Typhoon\/documentation\/Typhoon\/quick-start","doc:\/\/typhoon.Typhoon\/documentation\/Typhoon\/best-practices","doc:\/\/typhoon.Typhoon\/documentation\/Typhoon\/RetryPolicyService"],"anchor":"Related-Documentation"},{"title":"Articles","identifiers":["doc:\/\/typhoon.Typhoon\/documentation\/Typhoon\/installation","doc:\/\/typhoon.Typhoon\/documentation\/Typhoon\/quick-start","doc:\/\/typhoon.Typhoon\/documentation\/Typhoon\/best-practices"],"anchor":"Articles","generated":true}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/typhoon\/advanced-retry-strategies"]}],"hierarchy":{"paths":[["doc:\/\/typhoon.Typhoon\/documentation\/Typhoon"]]},"metadata":{"modules":[{"name":"Typhoon"}],"role":"article","title":"Advanced Retry Strategies","roleHeading":"Article"},"sections":[],"references":{"doc://typhoon.Typhoon/documentation/Typhoon":{"url":"\/documentation\/typhoon","type":"topic","title":"Typhoon","identifier":"doc:\/\/typhoon.Typhoon\/documentation\/Typhoon","kind":"symbol","role":"collection","abstract":[]},"doc://typhoon.Typhoon/documentation/Typhoon/RetryPolicyService":{"url":"\/documentation\/typhoon\/retrypolicyservice","abstract":[{"type":"codeVoice","code":"RetryPolicyService"},{"type":"text","text":" provides a high-level API for retrying asynchronous"},{"type":"text","text":" "},{"type":"text","text":"operations using configurable retry strategies."}],"kind":"symbol","title":"RetryPolicyService","identifier":"doc:\/\/typhoon.Typhoon\/documentation\/Typhoon\/RetryPolicyService","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"RetryPolicyService","kind":"identifier"}],"type":"topic","navigatorTitle":[{"text":"RetryPolicyService","kind":"identifier"}]},"doc://typhoon.Typhoon/documentation/Typhoon/installation":{"type":"topic","title":"Installation","role":"article","kind":"article","identifier":"doc:\/\/typhoon.Typhoon\/documentation\/Typhoon\/installation",