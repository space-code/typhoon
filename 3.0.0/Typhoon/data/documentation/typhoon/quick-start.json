{"variants":[{"paths":["\/documentation\/typhoon\/quick-start"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"modules":[{"name":"Typhoon"}],"roleHeading":"Article","title":"Quick Start","role":"article"},"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"article","abstract":[{"text":"Get up and running with Typhoon in minutes.","type":"text"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/typhoon.Typhoon\/documentation\/Typhoon\/quick-start"},"sections":[],"hierarchy":{"paths":[["doc:\/\/typhoon.Typhoon\/documentation\/Typhoon"]]},"seeAlsoSections":[{"title":"Related Documentation","identifiers":["doc:\/\/typhoon.Typhoon\/documentation\/Typhoon\/RetryPolicyService","doc:\/\/typhoon.Typhoon\/documentation\/Typhoon\/RetryPolicyStrategy"],"anchor":"Related-Documentation"},{"anchor":"Articles","title":"Articles","identifiers":["doc:\/\/typhoon.Typhoon\/documentation\/Typhoon\/installation","doc:\/\/typhoon.Typhoon\/documentation\/Typhoon\/advanced-retry-strategies","doc:\/\/typhoon.Typhoon\/documentation\/Typhoon\/best-practices"],"generated":true}],"primaryContentSections":[{"content":[{"anchor":"Overview","level":2,"text":"Overview","type":"heading"},{"inlineContent":[{"type":"text","text":"Typhoon is a powerful retry policy framework for Swift that helps you handle transient failures gracefully. This guide will help you integrate Typhoon into your project and start using retry policies immediately."}],"type":"paragraph"},{"anchor":"Basic-Usage","level":2,"text":"Basic Usage","type":"heading"},{"anchor":"Your-First-Retry","level":3,"text":"Your First Retry","type":"heading"},{"inlineContent":[{"text":"Import Typhoon and create a retry service with a simple constant strategy:","type":"text"}],"type":"paragraph"},{"code":["import Typhoon","","let retryService = RetryPolicyService(","    strategy: .constant(retry: 3, duration: .seconds(1))",")","","do {","    let result = try await retryService.retry {","        try await fetchDataFromAPI()","    }","    print(\"Success: \\(result)\")","} catch {","    print(\"Failed after 3 retries: \\(error)\")","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"This will:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Try your operation immediately"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If it fails, wait 1 second and retry"}]}]},{"content":[{"inlineContent":[{"text":"Repeat up to 3 times","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"Network-Request-Example","level":3,"text":"Network Request Example","type":"heading"},{"inlineContent":[{"type":"text","text":"Here’s a practical example with URLSession:"}],"type":"paragraph"},{"code":["import Foundation","import Typhoon","","func fetchUser(id: String) async throws -> User {","    let retryService = RetryPolicyService(","        strategy: .exponential(retry: 3, duration: .milliseconds(500))","    )","    ","    return try await retryService.retry {","        let url = URL(string: \"https:\/\/api.example.com\/users\/\\(id)\")!","        let (data, response) = try await URLSession.shared.data(from: url)","        ","        guard let httpResponse = response as? HTTPURLResponse,","              httpResponse.statusCode == 200 else {","            throw NetworkError.invalidResponse","        }","        ","        return try JSONDecoder().decode(User.self, from: data)","    }","}"],"syntax":"swift","type":"codeListing"},{"anchor":"Choosing-a-Strategy","level":2,"text":"Choosing a Strategy","type":"heading"},{"inlineContent":[{"text":"Typhoon provides three retry strategies:","type":"text"}],"type":"paragraph"},{"anchor":"Constant-Strategy","level":3,"text":"Constant Strategy","type":"heading"},{"inlineContent":[{"type":"text","text":"Best for predictable, fixed delays:"}],"type":"paragraph"},{"code":["\/\/ Retry 5 times with 2 seconds between attempts",".constant(retry: 5, duration: .seconds(2))"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Timeline:"}],"type":"strong"},{"text":" 0s (initial) → 2s → 2s → 2s → 2s → 2s","type":"text"}],"type":"paragraph"},{"anchor":"Exponential-Strategy","level":3,"text":"Exponential Strategy","type":"heading"},{"inlineContent":[{"type":"text","text":"Ideal for backing off from failing services:"}],"type":"paragraph"},{"code":["\/\/ Retry 4 times with exponentially increasing delays",".exponential(retry: 4, multiplier: 2.0, duration: .seconds(1))"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Timeline:"}]},{"type":"text","text":" 0s (initial) → 1s → 2s → 4s → 8s"}],"type":"paragraph"},{"anchor":"Exponential-with-Jitter","level":3,"text":"Exponential with Jitter","type":"heading"},{"inlineContent":[{"text":"Best for preventing thundering herd problems:","type":"text"}],"type":"paragraph"},{"code":["\/\/ Retry with exponential backoff, jitter, and cap",".exponential(","    retry: 5,","    jitterFactor: 0.2,","    maxInterval: .seconds(30),","    multiplier: 2.0,","    duration: .seconds(1)",")"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Timeline:"}],"type":"strong"},{"text":" 0s (initial) → ~1s → ~2s → ~4s → ~8s → ~16s (with randomization)","type":"text"}],"type":"paragraph"},{"anchor":"Common-Patterns","level":2,"text":"Common Patterns","type":"heading"},{"anchor":"Wrapping-in-a-Service-Class","level":3,"text":"Wrapping in a Service Class","type":"heading"},{"inlineContent":[{"text":"Create a reusable service with built-in retry logic:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["import Typhoon","","class APIClient {","    private let retryService = RetryPolicyService(","        strategy: .exponential(retry: 3, duration: .milliseconds(500))","    )","    ","    func get<T: Decodable>(endpoint: String) async throws -> T {","        try await retryService.retry {","            let url = URL(string: \"https:\/\/api.example.com\/\\(endpoint)\")!","            let (data, _) = try await URLSession.shared.data(from: url)","            return try JSONDecoder().decode(T.self, from: data)","        }","    }","}","","\/\/ Usage","let client = APIClient()","let user: User = try await client.get(endpoint: \"users\/123\")"]},{"text":"Error Handling","anchor":"Error-Handling","type":"heading","level":3},{"inlineContent":[{"text":"Handle specific errors after all retries are exhausted:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["do {","    let data = try await retryService.retry {","        try await performOperation()","    }","    \/\/ Handle success","} catch NetworkError.serverUnavailable {","    print(\"Server is down\")","} catch NetworkError.timeout {","    print(\"Request timed out\")","} catch {","    print(\"Unexpected error: \\(error)\")","}"]},{"text":"Configuration for Different Scenarios","anchor":"Configuration-for-Different-Scenarios","type":"heading","level":3},{"type":"codeListing","syntax":"swift","code":["\/\/ Quick operations (file I\/O, cache access)","let quickRetry = RetryPolicyService(","    strategy: .constant(retry: 3, duration: .milliseconds(100))",")","","\/\/ Network requests","let networkRetry = RetryPolicyService(","    strategy: .exponential(retry: 4, multiplier: 1.5, duration: .seconds(1))",")","","\/\/ Critical operations (payments, data persistence)","let criticalRetry = RetryPolicyService(","    strategy: .exponential(","        retry: 5,","        jitterFactor: 0.15,","        maxInterval: .seconds(60),","        multiplier: 2.0,","        duration: .seconds(2)","    )",")"]},{"text":"Next Steps","anchor":"Next-Steps","type":"heading","level":2},{"inlineContent":[{"text":"Now that you have the basics, explore:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"doc:\/\/typhoon.Typhoon\/documentation\/Typhoon\/advanced-retry-strategies","type":"reference"},{"type":"text","text":" - Deep dive into retry strategies"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/typhoon.Typhoon\/documentation\/Typhoon\/best-practices"},{"text":" - Learn best practices and patterns","type":"text"}]}]}],"type":"unorderedList"}],"kind":"content"}],"references":{"doc://typhoon.Typhoon/documentation/Typhoon/best-practices":{"type":"topic","abstract":[{"text":"Learn the recommended patterns and practices for using Typhoon effectively.","type":"text"}],"identifier":"doc:\/\/typhoon.Typhoon\/documentation\/Typhoon\/best-practices","title":"Best Practices","kind":"article","url":"\/documentation\/typhoon\/best-practices","role":"article"},"doc://typhoon.Typhoon/documentation/Typhoon/advanced-retry-strategies":{"url":"\/documentation\/typhoon\/advanced-retry-strategies","abstract":[{"type":"text","text":"Master advanced retry patterns and optimization techniques."}],"title":"Advanced Retry Strategies","type":"topic","kind":"article","identifier":"doc:\/\/typhoon.Typhoon\/documentation\/Typhoon\/advanced-retry-strategies","role":"article"},"doc://typhoon.Typhoon/documentation/Typhoon/RetryPolicyService":{"url":"\/documentation\/typhoon\/retrypolicyservice","abstract":[{"type":"codeVoice","code":"RetryPolicyService"},{"type":"text","text":" provides a high-level API for retrying asynchronous"},{"type":"text","text":" "},{"type":"text","text":"operations using configurable retry strategies."}],"kind":"symbol","title":"RetryPolicyService","identifier":"doc:\/\/typhoon.Typhoon\/documentation\/Typhoon\/RetryPolicyService","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"RetryPolicyService","kind":"identifier"}],"type":"topic","navigatorTitle":[{"text":"RetryPolicyService","kind":"identifier"}]},"doc://typhoon.Typhoon/documentation/Typhoon/installation":{"type":"topic","title":"Installation","role":"article","kind":"article","identifier":"doc:\/\/typhoon.Typhoon\/documentation\/Typhoon\/installation","url":"\/documentation\/typhoon\/installation","abstract":[{"type":"text","text":"A guide to installing the Typhoon package into your Swift project using Swift Package Manager."}]},"doc://typhoon.Typhoon/documentation/Typhoon":{"url":"\/documentation\/typhoon","type":"topic","title":"Typhoon","identifier":"doc:\/\/typhoon.Typhoon\/documentation\/Typhoon","kind":"symbol","role":"collection","abstract":[]},"doc://typhoon.Typhoon/documentation/Typhoon/RetryPolicyStrategy":{"abstract":[{"type":"text","text":"A strategy used to define different retry policies."}],"role":"symbol","type":"topic","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"RetryPolicyStrategy"}],"navigatorTitle":[{"kind":"identifier","text":"RetryPolicyStrategy"}],"identifier":"doc:\/\/typhoon.Typhoon\/documentation\/Typhoon\/RetryPolicyStrategy","title":"RetryPolicyStrategy","kind":"symbol","url":"\/documentation\/typhoon\/retrypolicystrategy"}}}